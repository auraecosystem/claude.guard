#!/usr/bin/env bash
# claude-panic — one-shot incident-response kill switch for the workspace's
# claude session. Snapshots forensic state to the host, then stops the
# containers (but leaves the volumes intact so the snapshots can be cross-
# checked against the live record afterward).
#
# Use when something has clearly gone wrong: an unexplained monitor alert, a
# tool call you don't recognize, network behavior that doesn't match the
# task, a suspected exfil. The point of one command is that you don't have to
# remember the order of `claude-audit --archive` → `docker logs` →
# `docker compose stop` while under stress.
#
# Snapshot lands at:
#   ${CLAUDE_PANIC_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/claude-monitor/panic}/<workspace-id>/<UTC>/
#
# Containers are stopped with `docker stop` (NOT `docker rm`, NOT `down -v`):
# the named volumes survive so a later `claude-audit`, manual `docker run -v
# claude-audit-<id>:/audit:ro ...`, or just reading the host snapshot still
# works. Use `docker compose down -v` explicitly if you want to delete the
# volumes after taking the snapshot.
#
# Usage:
#   claude-panic [options]
#
# Options:
#   --reason TEXT      free-text reason written into panic-report.md
#   --workspace DIR    target another workspace (default: $CLAUDE_WORKSPACE,
#                      else git repo root, else $PWD — same as claude-audit)
#   --keep-running     snapshot but do not stop the containers
#   --no-archive       stop the containers but do not snapshot
#   --no-ntfy          do not send the ntfy notification even if configured
#   -h, --help         show this help
#
# Best-effort by design: each step (audit archive, egress archive, per-container
# docker logs, compose state, stop) is isolated. A failure in one writes a
# STEP FAILED line into the report and the rest still run, because partial
# evidence is much better than aborting halfway because one volume was missing.
set -euo pipefail

usage() {
  awk 'NR==1 {next} /^#/ {sub(/^# ?/, ""); print; next} {exit}' "$0"
}

# Resolve our own location through any symlink (setup.bash installs this as
# ~/.local/bin/claude-panic → repo/bin/claude-panic) so lib/ next to the real
# script is found regardless of which path was typed. BSD readlink on macOS
# lacks -f, so we walk the chain by hand.
self="${BASH_SOURCE[0]}"
while [[ -L "$self" ]]; do
  link="$(readlink "$self")"
  case "$link" in
  /*) self="$link" ;;
  *) self="${self%/*}/$link" ;;
  esac
done
self_dir="$(cd "${self%/*}" && pwd)"
repo_root="$(cd "$self_dir/.." && pwd)"

# shellcheck source=lib/volume-id.bash disable=SC1091
source "$self_dir/lib/volume-id.bash"
# shellcheck source=lib/audit-archive.bash disable=SC1091
source "$self_dir/lib/audit-archive.bash"
# shellcheck source=lib/egress-archive.bash disable=SC1091
source "$self_dir/lib/egress-archive.bash"

canonicalize() {
  realpath -m "$1" 2>/dev/null && return
  realpath "$1" 2>/dev/null && return
  readlink -f "$1" 2>/dev/null && return
  printf '%s\n' "$1"
}

reason=""
workspace_override="${CLAUDE_WORKSPACE:-}"
keep_running=false
do_archive=true
do_ntfy=true

while [[ $# -gt 0 ]]; do
  case "$1" in
  --reason)
    [[ $# -ge 2 ]] || {
      echo "claude-panic: --reason needs a text argument" >&2
      exit 2
    }
    reason="$2"
    shift 2
    ;;
  --workspace)
    [[ $# -ge 2 ]] || {
      echo "claude-panic: --workspace needs a directory" >&2
      exit 2
    }
    workspace_override="$2"
    shift 2
    ;;
  --keep-running)
    keep_running=true
    shift
    ;;
  --no-archive)
    do_archive=false
    shift
    ;;
  --no-ntfy)
    do_ntfy=false
    shift
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  *)
    echo "claude-panic: unknown argument: $1 (try --help)" >&2
    exit 2
    ;;
  esac
done

if [[ -n "$workspace_override" ]]; then
  workspace_folder="$(canonicalize "$workspace_override")"
else
  repo=$(git rev-parse --show-toplevel 2>/dev/null || true)
  workspace_folder="${repo:-$PWD}"
fi
ws_id="$(claude_volume_id "$workspace_folder")"

# Snapshot path. Per-workspace so multiple projects' incidents don't collide.
panic_root="${CLAUDE_PANIC_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/claude-monitor/panic}"
ts="$(date -u +%Y%m%dT%H%M%SZ)"
snapshot_dir="$panic_root/$ws_id/$ts"

report=""
step_count=0
fail_count=0

# Report writer: append a one-line status entry. Captured into the on-disk
# report at the end so we don't depend on the snapshot dir existing yet.
log_step() {
  local status="$1" name="$2" detail="${3:-}"
  step_count=$((step_count + 1))
  [[ "$status" == "FAIL" ]] && fail_count=$((fail_count + 1))
  report+=$'\n'"- [$status] $name${detail:+ — $detail}"
}

# Run a step, prefix its stderr with the step name into the report, never
# abort the panic flow on failure (set -e is bypassed via `|| rc=$?`).
run_step() {
  local name="$1"
  shift
  local rc=0
  "$@" || rc=$?
  if ((rc == 0)); then
    log_step OK "$name"
  else
    log_step FAIL "$name" "exit=$rc"
  fi
  return 0
}

mkdir -p "$snapshot_dir" 2>/dev/null || {
  echo "claude-panic: cannot create snapshot dir $snapshot_dir" >&2
  exit 1
}

echo "claude-panic: workspace $workspace_folder" >&2
echo "claude-panic: snapshot -> $snapshot_dir" >&2

# ── Identify the workspace's containers ──────────────────────────────────────
# Devcontainer labels every container it launches with the host folder it was
# created for. We use that to scope all docker operations to THIS workspace,
# never touching unrelated projects' containers.
container_ids=""
if command -v docker >/dev/null 2>&1 && docker ps >/dev/null 2>&1; then
  container_ids=$(
    docker ps -a \
      --filter "label=devcontainer.local_folder=$workspace_folder" \
      --format '{{.ID}}' || true
  )
fi

if [[ -z "$container_ids" ]]; then
  log_step WARN "identify containers" "no containers found for $workspace_folder"
else
  count=$(printf '%s\n' "$container_ids" | wc -l | tr -d ' ')
  log_step OK "identify containers" "$count container(s)"
fi

# ── Archive the audit + egress volumes (best-effort, idempotent) ─────────────
audit_vol="claude-audit-$ws_id"
egress_vol="claude-egress-$ws_id"
image="$(claude_monitor_image "$repo_root/.devcontainer/Dockerfile.monitor")"

if $do_archive; then
  # claude_archive_audit_volume snapshots into <archive_root>/<volname>/<UTC>.jsonl
  # under XDG_STATE_HOME. We additionally copy the result into the panic dir so
  # the entire incident's evidence is in one path.
  audit_root="$(claude_audit_archive_dir)"
  egress_root="$(claude_egress_archive_dir)"

  if docker volume inspect "$audit_vol" >/dev/null 2>&1; then
    run_step "archive audit volume" claude_archive_audit_volume \
      "$audit_vol" "$image" "$audit_root" "${CLAUDE_AUDIT_ARCHIVE_KEEP:-10}"
    latest="$(claude_latest_audit_archive "$audit_vol" "$audit_root")"
    if [[ -n "$latest" && -f "$latest" ]]; then
      if cp "$latest" "$snapshot_dir/audit.jsonl" 2>/dev/null; then
        log_step OK "copy audit to snapshot"
      else
        log_step FAIL "copy audit to snapshot"
      fi
    else
      log_step WARN "copy audit to snapshot" "no archive produced (empty log?)"
    fi
  else
    log_step WARN "archive audit volume" "volume $audit_vol does not exist"
  fi

  if docker volume inspect "$egress_vol" >/dev/null 2>&1; then
    run_step "archive egress volume" claude_archive_egress_volume \
      "$egress_vol" "$image" "$egress_root" "${CLAUDE_EGRESS_ARCHIVE_KEEP:-10}"
    latest="$(claude_latest_egress_archive "$egress_vol" "$egress_root")"
    if [[ -n "$latest" && -f "$latest" ]]; then
      if cp "$latest" "$snapshot_dir/egress-access.log" 2>/dev/null; then
        log_step OK "copy egress to snapshot"
      else
        log_step FAIL "copy egress to snapshot"
      fi
    else
      log_step WARN "copy egress to snapshot" "no archive produced (empty log?)"
    fi
  else
    log_step WARN "archive egress volume" "volume $egress_vol does not exist"
  fi

  # ── Per-container docker logs ──────────────────────────────────────────────
  # Combined stdout+stderr per container. Names are unstable across compose
  # versions, so we identify by the "com.docker.compose.service" label rather
  # than parsing the name string.
  if [[ -n "$container_ids" ]]; then
    while read -r cid; do
      [[ -z "$cid" ]] && continue
      svc=$(docker inspect --format '{{ index .Config.Labels "com.docker.compose.service" }}' \
        "$cid" 2>/dev/null || echo "")
      [[ -z "$svc" ]] && svc="unknown-$cid"
      logfile="$snapshot_dir/${svc}.log"
      if docker logs "$cid" >"$logfile" 2>&1; then
        log_step OK "docker logs $svc" "$(wc -c <"$logfile" | tr -d ' ') bytes"
      else
        log_step FAIL "docker logs $svc"
      fi
    done <<<"$container_ids"
  fi

  # ── Compose state snapshot ─────────────────────────────────────────────────
  # `docker ps` for the labelled containers, plus the resolved compose config
  # (so we can prove what was running and how it was configured at the moment
  # of panic). compose config may fail if the compose file is no longer at the
  # expected path; that's logged, not fatal.
  if [[ -n "$container_ids" ]]; then
    if docker ps -a \
      --filter "label=devcontainer.local_folder=$workspace_folder" \
      --format 'table {{.Names}}\t{{.Image}}\t{{.Status}}\t{{.RunningFor}}' \
      >"$snapshot_dir/compose-state.txt" 2>&1; then
      log_step OK "compose state"
    else
      log_step FAIL "compose state"
    fi
  fi
fi

# ── Stop containers (the kill switch) ────────────────────────────────────────
if $keep_running; then
  log_step OK "stop containers" "skipped (--keep-running)"
elif [[ -n "$container_ids" ]]; then
  # docker stop sends SIGTERM then SIGKILL on timeout; default 10s is fine for
  # the firewall/monitor/app set. Stopping all in one call is parallel.
  # shellcheck disable=SC2086  # word-splitting is intentional
  if docker stop $container_ids >/dev/null 2>&1; then
    log_step OK "stop containers" "stopped $(printf '%s\n' "$container_ids" | wc -l | tr -d ' ')"
  else
    log_step FAIL "stop containers"
  fi
else
  log_step WARN "stop containers" "no containers to stop"
fi

# ── ntfy notification (best-effort, fire-and-forget) ─────────────────────────
ntfy_conf="$HOME/.config/claude-monitor/ntfy.conf"
if $do_ntfy && [[ -f "$ntfy_conf" ]] && command -v curl >/dev/null 2>&1; then
  # Re-read the conf rather than sourcing it (the conf format is shell-style
  # KEY=VALUE; we want NTFY_URL and NTFY_TOPIC out of it without executing
  # arbitrary lines).
  ntfy_url=$(grep -E '^NTFY_URL=' "$ntfy_conf" | tail -1 | cut -d= -f2- | tr -d '"')
  ntfy_topic=$(grep -E '^NTFY_TOPIC=' "$ntfy_conf" | tail -1 | cut -d= -f2- | tr -d '"')
  if [[ -n "$ntfy_url" && -n "$ntfy_topic" ]]; then
    body="[claude-panic] incident snapshot $ts
workspace: $workspace_folder
reason: ${reason:-(none)}
snapshot: $snapshot_dir"
    if curl -sS --max-time 5 -d "$body" "$ntfy_url/$ntfy_topic" >/dev/null 2>&1; then
      log_step OK "ntfy" "sent to $ntfy_url/$ntfy_topic"
    else
      log_step FAIL "ntfy" "post failed"
    fi
  else
    log_step WARN "ntfy" "config missing NTFY_URL or NTFY_TOPIC"
  fi
elif $do_ntfy; then
  log_step WARN "ntfy" "no config at $ntfy_conf"
else
  log_step OK "ntfy" "skipped (--no-ntfy)"
fi

# ── Per-artifact sha256 (so the report itself can be checked later) ──────────
# These hashes are the anchor a future forensics review uses to confirm the
# snapshot hasn't been edited on disk. Best-effort: missing files just don't
# contribute a line.
hashes=""
for f in "$snapshot_dir"/*; do
  [[ -f "$f" ]] || continue
  [[ "$(basename "$f")" == "panic-report.md" ]] && continue
  if h=$(sha256sum "$f" 2>/dev/null | cut -d' ' -f1); then
    hashes+=$'\n'"  $(basename "$f"): $h"
  fi
done

# ── Write the report ─────────────────────────────────────────────────────────
{
  printf '%s\n\n' "# claude-panic report"
  printf '%s\n' "- timestamp: $ts"
  printf '%s\n' "- workspace: $workspace_folder"
  printf '%s\n' "- workspace id: $ws_id"
  printf '%s\n' "- snapshot dir: $snapshot_dir"
  printf '%s\n' "- reason: ${reason:-(none)}"
  printf '%s\n' "- archive: $($do_archive && echo yes || echo no)"
  printf '%s\n' "- containers stopped: $($keep_running && echo no || echo yes)"
  printf '\n## Steps (%d total, %d failed)\n' "$step_count" "$fail_count"
  printf '%s\n' "$report"
  printf '\n## Artifact sha256\n'
  printf '%s\n' "$hashes"
} >"$snapshot_dir/panic-report.md"

# ── Final user-facing summary ────────────────────────────────────────────────
printf '\nclaude-panic: %d step(s), %d failed\n' "$step_count" "$fail_count" >&2
printf 'claude-panic: report -> %s/panic-report.md\n' "$snapshot_dir" >&2
if ((fail_count > 0)); then
  printf 'claude-panic: WARNING — %d step(s) failed; see report\n' "$fail_count" >&2
  exit 1
fi
exit 0
