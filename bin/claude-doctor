#!/usr/bin/env bash
# claude-doctor — read-only health check for the secure-claude-code-defaults
# stack. Reports the REAL enforcement state so you can tell whether `claude`
# will run sandboxed or has silently degraded to host execution.
#
# Strictly read-only: it never launches a container, never writes, and has no
# side effects beyond `docker ps`-style queries. Exit status:
#   0  PROTECTED   — a sandboxed launch should succeed and the monitor is wired
#   1  DEGRADED    — usable but missing a meaningful protection (e.g. no monitor
#                    key, or only gVisor where KVM/Kata would be stronger)
#   2  UNPROTECTED — a sandboxed launch cannot happen (missing tool / daemon),
#                    so `claude` would fail closed or run on the bare host
set -euo pipefail

status() { printf ':: %s\n' "$1"; }
warn() { printf '!! %s\n' "$1" >&2; }

# Resolve our own symlink (setup.bash installs this as ~/.local/bin/claude-doctor
# → repo/bin/claude-doctor) so lib/ is found next to the real script, not the link.
canonicalize() {
  if command -v realpath >/dev/null 2>&1; then
    realpath "$1" 2>/dev/null && return
  fi
  if readlink -f "$1" >/dev/null 2>&1; then
    readlink -f "$1"
    return
  fi
  echo "$1"
}
SELF_DIR="$(cd "$(dirname "$(canonicalize "$0")")" && pwd)"

# Reasons accumulate into these arrays; the final verdict is the worst of them.
DEGRADED_REASONS=()
UNPROTECTED_REASONS=()
degrade() { DEGRADED_REASONS+=("$1"); }
unprotect() { UNPROTECTED_REASONS+=("$1"); }

# ── Container runtime ────────────────────────────────────────────────────────
status "Container runtime"
runtime="unknown"
if [[ -r "$SELF_DIR/lib/runtime-detect.bash" ]]; then
  # shellcheck source=lib/runtime-detect.bash disable=SC1091
  source "$SELF_DIR/lib/runtime-detect.bash"
  runtime="$(detect_container_runtime)"
else
  warn "   lib/runtime-detect.bash not found next to this script — cannot detect runtime"
  unprotect "runtime-detect.bash missing (broken install)"
fi
printf '   effective runtime: %s\n' "$runtime"

if [[ -e /dev/kvm ]]; then
  printf '   /dev/kvm: present (hardware virtualization available)\n'
else
  printf '   /dev/kvm: absent (no KVM — Kata/Firecracker microVMs unavailable)\n'
fi

case "$runtime" in
kata-fc)
  printf '   isolation: Kata/Firecracker microVM (strongest)\n'
  [[ -e /dev/kvm ]] || degrade "runtime is kata-fc but /dev/kvm is absent — launch may fail"
  ;;
runsc)
  printf '   isolation: gVisor (runsc) — userspace kernel\n'
  ;;
*)
  degrade "unrecognized container runtime: $runtime"
  ;;
esac

# ── Required tools on PATH ───────────────────────────────────────────────────
status "Required tools"
# docker, devcontainer, and uv are load-bearing for a sandboxed launch; their
# absence means `claude` cannot start a container (fails closed / host only).
for tool in docker devcontainer uv; do
  if command -v "$tool" >/dev/null 2>&1; then
    printf '   %-12s found  (%s)\n' "$tool" "$(command -v "$tool")"
  else
    printf '   %-12s MISSING\n' "$tool"
    unprotect "$tool not on PATH (sandboxed launch cannot start)"
  fi
done
# jq/curl/dig back host-mode firewall + monitor plumbing; their absence weakens
# protection but does not block the container path.
for tool in jq curl dig; do
  if command -v "$tool" >/dev/null 2>&1; then
    printf '   %-12s found  (%s)\n' "$tool" "$(command -v "$tool")"
  else
    printf '   %-12s missing (host-mode firewall/monitor helpers degraded)\n' "$tool"
    degrade "$tool not on PATH"
  fi
done

# ── Docker daemon reachability ───────────────────────────────────────────────
status "Docker daemon"
if command -v docker >/dev/null 2>&1; then
  if docker ps >/dev/null 2>&1; then
    printf '   reachable: yes\n'
  else
    printf '   reachable: NO (daemon not running or no permission)\n'
    unprotect "Docker daemon not reachable — no container can launch"
  fi
else
  printf '   reachable: n/a (docker not installed)\n'
fi

# ── Managed settings ─────────────────────────────────────────────────────────
status "Managed settings"
managed="/etc/claude-code/managed-settings.json"
if [[ -f "$managed" ]]; then
  # Root-owned + not world/group-writable is what makes managed-settings
  # tamper-resistant; report the actual state rather than assuming.
  owner_uid="$(stat -c %u "$managed" 2>/dev/null || stat -f %u "$managed" 2>/dev/null || echo '?')"
  perms="$(stat -c %a "$managed" 2>/dev/null || stat -f %Lp "$managed" 2>/dev/null || echo '?')"
  printf '   %s present (uid=%s mode=%s)\n' "$managed" "$owner_uid" "$perms"
  if [[ "$owner_uid" != "0" ]]; then
    degrade "managed-settings.json not root-owned (uid=$owner_uid) — tamperable"
  fi
  # Writable by group or other (any of the lower two octal digits has the 2 bit)
  # means a non-root user could edit it; flag that.
  if [[ "$perms" =~ ^[0-7]?[2367][0-7]$ || "$perms" =~ ^[0-7]?[0-7][2367]$ ]]; then
    degrade "managed-settings.json is group/other-writable (mode=$perms)"
  fi
else
  printf '   %s ABSENT — security defaults not enforced (run setup.bash)\n' "$managed"
  degrade "managed-settings.json missing — run setup.bash"
fi

# ── Monitor configuration ────────────────────────────────────────────────────
status "AI monitor"
monitor_env="$HOME/.config/claude-monitor/env"
if [[ "${MONITOR_DISABLED:-}" == "1" ]]; then
  printf '   MONITOR_DISABLED=1 — the AI monitor is OFF\n'
  degrade "monitor explicitly disabled (MONITOR_DISABLED=1)"
elif [[ -n "${MONITOR_API_KEY:-}" || -n "${ANTHROPIC_API_KEY:-}" || -n "${VENICE_INFERENCE_KEY:-}" ]]; then
  printf '   monitor API key present in environment\n'
elif [[ -f "$monitor_env" ]]; then
  printf '   %s present (key sourced at launch)\n' "$monitor_env"
else
  printf '   no monitor API key found (env or %s)\n' "$monitor_env"
  degrade "no monitor API key — tool calls run unmonitored"
fi

# ── Devcontainer for the current directory ───────────────────────────────────
status "Devcontainer for $PWD (best-effort)"
folder=""
if command -v git >/dev/null 2>&1; then
  folder="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || true)"
fi
[[ -n "$folder" ]] || folder="$PWD"
if command -v docker >/dev/null 2>&1 && docker ps >/dev/null 2>&1; then
  # `|| true`: head closing the pipe early can SIGPIPE docker; with pipefail
  # that would abort under set -e, and this probe is purely informational.
  running="$(docker ps --filter "label=devcontainer.local_folder=$folder" -q 2>/dev/null | head -1 || true)"
  if [[ -n "$running" ]]; then
    printf '   running container for %s: %s\n' "$folder" "$running"
  else
    printf '   no running container for %s (one will start on next launch)\n' "$folder"
  fi
else
  printf '   cannot check (docker unavailable)\n'
fi

# ── Prebuilt image for the next launch (informational; never changes verdict) ─
# Building locally is the safe default, not a degradation — so this only reports
# what the next `claude` launch will do, mirroring bin/lib/resolve-image.bash.
status "Prebuilt sandbox image"
if [[ -r "$SELF_DIR/lib/resolve-image.bash" ]] && command -v docker >/dev/null 2>&1; then
  # shellcheck source=lib/resolve-image.bash disable=SC1091
  source "$SELF_DIR/lib/resolve-image.bash"
  repo_dir="$(git -C "$SELF_DIR" rev-parse --show-toplevel 2>/dev/null || echo "$SELF_DIR/..")"
  probe="$(_sccd_prebuilt_probe "$repo_dir")"
  pb_state="${probe%%$'\t'*}"
  pb_ref="${probe#*$'\t'}"
  pb_ref="${pb_ref%%$'\t'*}"
  case "$pb_state" in
  available) printf '   next launch: PULL prebuilt (%s)\n' "$pb_ref" ;;
  miss) printf '   next launch: build locally — no image published for this commit (is the package public? has CI published it yet?)\n' ;;
  dirty) printf '   next launch: build locally — uncommitted changes in the repo\n' ;;
  disabled) printf '   next launch: build locally — SCCD_NO_PREBUILT=1\n' ;;
  no-remote) printf '   next launch: build locally — origin is not a github.com remote\n' ;;
  *) printf '   next launch: build locally\n' ;;
  esac
else
  printf '   cannot check (docker unavailable or resolve-image.bash missing)\n'
fi

# ── Verdict ──────────────────────────────────────────────────────────────────
# Worst reason wins: any UNPROTECTED reason → exit 2, else any DEGRADED → exit 1.
print_reasons() {
  local r
  for r in "$@"; do printf '   - %s\n' "$r"; done
}

printf '\n'
if ((${#UNPROTECTED_REASONS[@]} > 0)); then
  status "VERDICT: UNPROTECTED"
  print_reasons ${UNPROTECTED_REASONS[@]+"${UNPROTECTED_REASONS[@]}"}
  print_reasons ${DEGRADED_REASONS[@]+"${DEGRADED_REASONS[@]}"}
  exit 2
fi
if ((${#DEGRADED_REASONS[@]} > 0)); then
  status "VERDICT: DEGRADED"
  print_reasons ${DEGRADED_REASONS[@]+"${DEGRADED_REASONS[@]}"}
  exit 1
fi
status "VERDICT: PROTECTED"
exit 0
