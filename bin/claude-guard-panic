#!/usr/bin/env bash
# claude-guard panic — one-shot incident-response kill switch. Snapshots forensic
# state to the host, then stops the workspace's containers (volumes survive) and
# removes this host's claude-guard sandbox sessions (their saved records survive
# on the host; removal ignores CLAUDE_PERSIST — an incident kill is deliberate).
#
# Options:
#   --reason TEXT      free-text reason written into panic-report.md
#   --workspace DIR    target another workspace (default: $CLAUDE_WORKSPACE,
#                      else git repo root, else $PWD — same as claude-guard-audit)
#   --keep-running     snapshot but do not stop containers or remove sandboxes
#   --no-archive       stop containers / remove sandboxes but do not snapshot
#   --no-ntfy          do not send the ntfy notification even if configured
set -euo pipefail

# Incident snapshots carry the audit log (full tool_input.command / file_path /
# url — credential-bearing), docker logs, egress logs, and sbx session records
# (including each session's HMAC signing key, kept so a reviewer can verify the
# audit records' signatures). Restrict every dir and file this script creates to
# owner-only so another local user on a shared host cannot read a session's
# forensic record.
umask 077

usage() {
  awk 'NR==1 {next} /^#/ {sub(/^# ?/, ""); print; next} {exit}' "$0"
}

# Resolve our own location through any symlink chain to locate lib/ next to the
# real script. resolve-self.bash itself lives in lib/, so source it via the link's
# own directory first (the wrapper is always invoked beside its lib — claude-guard
# execs it by absolute path in bin/), then take the BSD-safe resolved dir.
self_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/resolve-self.bash disable=SC1091
source "$self_dir/lib/resolve-self.bash"
self_dir="$(resolve_self_dir "${BASH_SOURCE[0]}")"

# cg_warn lives in msg.bash; source it explicitly rather than leaning on
# egress-archive.bash's transitive include (which is unrelated to messaging and
# could drop it).
# shellcheck source=lib/msg.bash disable=SC1091
source "$self_dir/lib/msg.bash"
# shellcheck source=lib/volume-id.bash disable=SC1091
source "$self_dir/lib/volume-id.bash"
# shellcheck source=lib/audit-archive.bash disable=SC1091
source "$self_dir/lib/audit-archive.bash"
# shellcheck source=lib/egress-archive.bash disable=SC1091
source "$self_dir/lib/egress-archive.bash"

# Normalize the path even when it no longer exists, so a deleted project still
# addresses its archive by the same id `claude` hashed. GNU `realpath -m` does this,
# but on BSD/macOS realpath/readlink both fail for a missing path and return the raw,
# un-normalized string — deriving a DIFFERENT id than Linux. python3 (a hard
# dependency of this stack) normalizes a non-existent path identically on every
# platform; the realpath/readlink chain is the fallback when it is somehow absent.
canonicalize() {
  command -v python3 >/dev/null 2>&1 &&
    python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$1" && return
  realpath "$1" 2>/dev/null && return
  readlink -f "$1" 2>/dev/null && return
  printf '%s\n' "$1"
}

reason=""
workspace_override="${CLAUDE_WORKSPACE:-}"
keep_running=false
do_archive=true
do_ntfy=true

need_arg() { [[ $# -ge 2 ]] || {
  echo "claude-guard panic: $1 needs an argument" >&2
  exit 2
}; } # kcov-ignore-line  the closing brace group is never credited as executed; the missing-arg path is covered by test_reason_missing_arg_exits_2 / test_workspace_missing_arg_exits_2
while [[ $# -gt 0 ]]; do
  case "$1" in
  --reason)
    need_arg "$@"
    reason="$2"
    shift 2
    ;;
  --workspace)
    need_arg "$@"
    workspace_override="$2"
    shift 2
    ;;
  --keep-running)
    keep_running=true
    shift
    ;;
  --no-archive)
    do_archive=false
    shift
    ;;
  --no-ntfy)
    do_ntfy=false
    shift
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  *)
    echo "claude-guard panic: unknown argument: $1 (try --help)" >&2
    exit 2
    ;;
  esac
done

if [[ -n "$workspace_override" ]]; then
  workspace_folder="$(canonicalize "$workspace_override")"
else
  repo=$(git rev-parse --show-toplevel 2>/dev/null || true)
  workspace_folder="${repo:-$PWD}"
fi
ws_id="$(claude_volume_id "$workspace_folder")"

panic_root="${CLAUDE_PANIC_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/claude-monitor/panic}"
ts="$(date -u +%Y%m%dT%H%M%SZ)"
snapshot_dir="$panic_root/$ws_id/$ts"

report=""
step_count=0
fail_count=0

# log_step <OK|WARN|FAIL> <name> [detail]
log_step() {
  local status="$1" name="$2" detail="${3:-}"
  step_count=$((step_count + 1))
  [[ "$status" == "FAIL" ]] && fail_count=$((fail_count + 1))
  report+=$'\n'"- [$status] $name${detail:+ — $detail}"
}

# step <name> <cmd...>  — run, log OK/FAIL with exit code, never abort.
step() {
  local name="$1"
  shift
  local rc=0
  "$@" || rc=$?
  if ((rc == 0)); then
    log_step OK "$name"
  else
    log_step FAIL "$name" "exit=$rc"
  fi
  return 0
}

# umask 077 already forces 0700 dirs / 0600 files, but chmod the dir explicitly
# and verify the post-condition: a pre-existing snapshot dir keeps its old mode
# through mkdir -p, and mkdir -p reports success on a dangling symlink under BSD —
# so trust the verified state (dir exists, owner-only), not mkdir's exit code.
mkdir -p "$snapshot_dir" 2>/dev/null && chmod 700 "$snapshot_dir" 2>/dev/null
if [[ ! -d "$snapshot_dir" ]]; then
  echo "claude-guard panic: cannot create snapshot dir $snapshot_dir" >&2
  echo "claude-guard panic: check directory permissions and free space, then retry (set CLAUDE_PANIC_DIR to use another location)." >&2
  exit 1
fi
perms="$(stat -c '%a' "$snapshot_dir" 2>/dev/null || stat -f '%Lp' "$snapshot_dir" 2>/dev/null || echo '')"
if [[ "$perms" != "700" ]]; then
  echo "claude-guard panic: snapshot dir $snapshot_dir is not owner-only (mode $perms); refusing to write secrets there" >&2
  exit 1
fi
echo "claude-guard panic: workspace $workspace_folder" >&2
echo "claude-guard panic: snapshot -> $snapshot_dir" >&2

# Devcontainer labels each container with its host folder; we scope every
# docker operation to THIS workspace by that label. An array (not a newline
# string) so each id stays a distinct argument to `docker stop` below — quoting
# a joined string would hand docker one bogus reference and stop nothing.
container_ids=()
if command -v docker >/dev/null 2>&1 && docker ps >/dev/null 2>&1; then
  # Read one id per line into the array. `mapfile` would be shorter but is bash
  # 4+; this wrapper has no bash-5 re-exec guard and must run on macOS's stock
  # bash 3.2, so use a portable while-read loop.
  # kcov-ignore-start  process substitution runs in a subshell kcov's DEBUG trap can't trace; the docker-scoped tests cover it
  while IFS= read -r _cid; do
    [[ -n "$_cid" ]] && container_ids+=("$_cid")
  done < <(docker ps -a \
    --filter "label=devcontainer.local_folder=$workspace_folder" \
    --format '{{.ID}}' || true)
  # kcov-ignore-end
fi
if ((${#container_ids[@]} == 0)); then
  log_step WARN "identify containers" "no containers found for $workspace_folder"
else
  log_step OK "identify containers" "${#container_ids[@]} container(s)"
fi

# The sbx microVM backend keeps each session's records on the host under
# $XDG_STATE_HOME/claude-guard/sbx: services/<base>/ (audit log, service logs,
# signing key) and method-filter-run/<base>/ (the read-only filter's own logs
# and config). Those are plain files, snapshotted even when the `sbx` tool is
# unavailable. Live sandboxes come from `sbx ls`, parsed conservatively (no
# machine-readable output exists): first token per line, only names shaped
# like sbx-launch.bash's sbx_session_base/sbx_sandbox_name mint (cg-<8 hex>-…).
# Panic is evidence-greedy: every claude-guard sandbox on the host is captured
# and removed, not just this workspace's — a sandbox name does not record its
# workspace, and missing an incident sandbox is worse than over-collecting.
sbx_state_root="${XDG_STATE_HOME:-$HOME/.local/state}/claude-guard/sbx"
sbx_session_dirs=()
for _d in "$sbx_state_root/services"/*/; do
  [[ -d "$_d" ]] && sbx_session_dirs+=("$_d")
done
sbx_names=()
sbx_listing=""
sbx_cli_ok=false
if ! command -v sbx >/dev/null 2>&1; then
  log_step WARN "identify sandboxes" "the 'sbx' sandbox tool is not installed — capturing this host's saved sandbox session files only"
elif ! sbx_listing="$(sbx ls 2>/dev/null)"; then
  log_step FAIL "identify sandboxes" "'sbx ls' failed — capturing this host's saved sandbox session files only"
else
  sbx_cli_ok=true
  while IFS= read -r _line; do
    _sname="${_line%%[[:space:]]*}"
    [[ "$_sname" =~ ^cg-[0-9a-f]{8}- ]] && sbx_names+=("$_sname")
  done <<<"$sbx_listing"
  if ((${#sbx_names[@]} == 0)); then
    log_step WARN "identify sandboxes" "no claude-guard sandboxes found"
  else
    log_step OK "identify sandboxes" "${#sbx_names[@]} sandbox(es)"
  fi
fi

# The monitor image (reader for the forensic archive helpers) is resolved lazily,
# only on the archive path. --no-archive is a fast evidence-free kill switch, so it
# must not read .devcontainer/Dockerfile.monitor (an incident may have left it in an
# odd state). Declared empty under set -u; the only consumer is archive_volume,
# called solely inside the `if "$do_archive"` block that assigns it. Mirrors
# gc-volumes.bash's deferred MONITOR_IMAGE resolution.
image=""

# archive_volume <label> <volname> <archive_root> <latest_fn> <archive_fn> <out> <keep>
# Common loop for the two archived forensic volumes (audit, egress): inspect →
# archive (retaining <keep> host snapshots) → copy newest into the panic dir
# under <out>. The archive helper returns 0 both when it wrote a fresh snapshot and
# when there was nothing to archive, and forensic_latest_archive returns the newest
# snapshot across ALL prior runs — so capture the pre-archive latest and treat the
# copy as a fresh capture only when the newest snapshot actually changed; otherwise
# note we copied a pre-existing one (mirrors print_blocked_egress_summary's compare).
archive_volume() {
  local label="$1" vol="$2" root="$3" latest_fn="$4" archive_fn="$5" out="$6" keep="$7"
  if ! docker volume inspect "$vol" >/dev/null 2>&1; then
    log_step WARN "archive $label" "volume $vol does not exist"
    return
  fi
  local prior
  prior="$("$latest_fn" "$vol" "$root")"
  step "archive $label" "$archive_fn" "$vol" "$image" "$root" "$keep"
  local latest
  latest="$("$latest_fn" "$vol" "$root")"
  if [[ -z "$latest" || ! -f "$latest" ]]; then
    log_step WARN "copy $label to snapshot" "no archive produced (empty log?)"
    return
  fi
  local detail=""
  [[ "$latest" == "$prior" ]] && detail="no new archive this run (copied most recent)"
  if cp "$latest" "$snapshot_dir/$out" 2>/dev/null; then
    log_step OK "copy $label to snapshot" "$detail"
  else
    log_step FAIL "copy $label to snapshot"
  fi
}

# _snapshot_sbx_listing OUT — the `sbx ls` view of the host, the sandbox
# analogue of compose-state.txt.
# shellcheck disable=SC2317,SC2329  # invoked indirectly via step's "$@" dispatch
_snapshot_sbx_listing() {
  printf '%s\n' "$sbx_listing" >"$1"
}

# _snapshot_sbx_network_log NAME OUT — capture NAME's outgoing-traffic decision
# log straight into the snapshot; the sandbox removal below destroys the
# original. A failed capture leaves no artifact behind (a truncated file would
# be hashed into the report as if it were the record).
# shellcheck disable=SC2317,SC2329  # invoked indirectly via step's "$@" dispatch
_snapshot_sbx_network_log() {
  sbx policy log "$1" --json >"$2" 2>/dev/null || {
    rm -f -- "$2"
    return 1
  }
}

# snapshot_sbx_dir_files <label> <dir> <prefix> — copy DIR's top-level regular
# files into the snapshot as <prefix><name>. poll.stop is a zero-byte teardown
# flag, not evidence; dotfiles (in-flight temp copies) never match the glob.
snapshot_sbx_dir_files() {
  local label="$1" dir="$2" prefix="$3"
  local f copied=0 failed=0
  for f in "$dir"/*; do
    [[ -f "$f" ]] || continue
    [[ "$(basename "$f")" == "poll.stop" ]] && continue
    if cp "$f" "$snapshot_dir/$prefix$(basename "$f")" 2>/dev/null; then
      copied=$((copied + 1))
    else
      failed=$((failed + 1))
    fi
  done
  if ((failed > 0)); then
    log_step FAIL "$label" "$failed of $((copied + failed)) file(s) not copied"
  elif ((copied == 0)); then
    log_step WARN "$label" "no files to copy"
  else
    log_step OK "$label" "$copied file(s)"
  fi
}

if "$do_archive"; then
  image="$(claude_monitor_image)"
  archive_volume "audit volume" "$(session_volume_name "$ws_id" audit)" \
    "$(claude_audit_archive_dir)" claude_latest_audit_archive \
    claude_archive_audit_volume audit.jsonl "${CLAUDE_AUDIT_ARCHIVE_KEEP:-10}"
  archive_volume "outgoing-traffic log" "$(session_volume_name "$ws_id" egress)" \
    "$(claude_egress_archive_dir)" claude_latest_egress_archive \
    claude_archive_egress_volume outgoing-traffic.log "${CLAUDE_AUDIT_ARCHIVE_KEEP:-10}"

  # Per-container docker logs + a compose-state snapshot.
  if ((${#container_ids[@]} > 0)); then
    for cid in "${container_ids[@]}"; do
      # kcov-ignore-start  multi-line command substitution credited to its closing line, covered by test_docker_logs_failure_recorded_as_fail
      svc=$(docker inspect --format '{{ index .Config.Labels "com.docker.compose.service" }}' \
        "$cid" 2>/dev/null || echo "")
      # kcov-ignore-end
      [[ -z "$svc" ]] && svc="unknown-$cid"
      logfile="$snapshot_dir/${svc}.log"
      if docker logs "$cid" >"$logfile" 2>&1; then
        log_step OK "docker logs $svc" "$(wc -c <"$logfile" | tr -d ' ') bytes"
      else
        log_step FAIL "docker logs $svc"
      fi
    done

    if docker ps -a --filter "label=devcontainer.local_folder=$workspace_folder" \
      --format 'table {{.Names}}\t{{.Image}}\t{{.Status}}\t{{.RunningFor}}' \
      >"$snapshot_dir/compose-state.txt" 2>&1; then
      log_step OK "compose state"
    else
      log_step FAIL "compose state"
    fi
  fi

  # sbx evidence. The outgoing-traffic capture must run BEFORE the removal
  # below: `sbx rm` destroys the only copy of a sandbox's decision log.
  if "$sbx_cli_ok"; then
    step "sandbox list" _snapshot_sbx_listing "$snapshot_dir/sbx-sandboxes.txt"
    if ((${#sbx_names[@]} > 0)); then
      for _sname in "${sbx_names[@]}"; do
        step "sandbox outgoing-traffic log ($_sname)" _snapshot_sbx_network_log \
          "$_sname" "$snapshot_dir/sbx-$_sname-outgoing-traffic.json"
      done
    fi
  fi
  if ((${#sbx_session_dirs[@]} > 0)); then
    for _d in "${sbx_session_dirs[@]}"; do
      _base="$(basename "$_d")"
      snapshot_sbx_dir_files "copy sandbox session files ($_base)" "$_d" "sbx-$_base-"
    done
  fi
  for _d in "$sbx_state_root/method-filter-run"/*/; do
    [[ -d "$_d" ]] || continue
    _base="$(basename "$_d")"
    snapshot_sbx_dir_files "copy read-only filter logs ($_base)" "$_d" "sbx-$_base-filter-"
  done
fi

# The kill switch. docker stop is SIGTERM-then-SIGKILL; passing every id in one
# call stops them in parallel.
if "$keep_running"; then
  log_step OK "stop containers" "skipped (--keep-running)"
elif ((${#container_ids[@]} > 0)); then
  if docker stop "${container_ids[@]}" >/dev/null 2>&1; then
    log_step OK "stop containers" "stopped ${#container_ids[@]}"
  else
    log_step FAIL "stop containers"
  fi
else
  log_step WARN "stop containers" "no containers to stop"
fi

# The sandbox kill switch: `sbx rm` destroys the microVM and its disk (the
# session's host-side records were copied above). Deliberately ignores
# CLAUDE_PERSIST — an incident kill is explicit.
sbx_removed=0
sbx_rm_failed=0
if "$keep_running"; then
  log_step OK "remove sandboxes" "skipped (--keep-running)"
elif ((${#sbx_names[@]} > 0)); then
  for _sname in "${sbx_names[@]}"; do
    if sbx rm "$_sname" >/dev/null 2>&1; then
      sbx_removed=$((sbx_removed + 1))
    else
      sbx_rm_failed=$((sbx_rm_failed + 1))
    fi
  done
  if ((sbx_rm_failed > 0)); then
    log_step FAIL "remove sandboxes" "$sbx_rm_failed of ${#sbx_names[@]} could not be removed — remove each manually with: sbx rm NAME"
  else
    log_step OK "remove sandboxes" "removed $sbx_removed"
  fi
else
  log_step WARN "remove sandboxes" "no sandboxes to remove"
fi

# ntfy (best-effort). Parse KEY=VALUE without sourcing — the conf is user-
# editable and shouldn't execute arbitrary lines on us.
ntfy_conf="$HOME/.config/claude-monitor/ntfy.conf"
if ! "$do_ntfy"; then
  log_step OK "ntfy" "skipped (--no-ntfy)"
elif [[ ! -f "$ntfy_conf" ]] || ! command -v curl >/dev/null 2>&1; then
  log_step WARN "ntfy" "no config at $ntfy_conf or curl missing"
else
  # Keys match what setup-ntfy.bash writes and monitorlib/ntfy.py reads:
  # lowercase `url=` / `topic=`. url defaults to https://ntfy.sh (setup-ntfy's
  # own default) when the conf omits it; topic has no default and must be set.
  # Split on the FIRST `=` only (sub() the leading `key=`), so a value that itself
  # contains `=` — a url with a query string, a topic with padding — survives intact
  # rather than being truncated at the first `=` as a field-split would do.
  ntfy_url=$(awk '/^url=/{sub(/^url=/,""); gsub(/"/,""); u=$0} END{print u}' "$ntfy_conf")
  ntfy_url="${ntfy_url:-https://ntfy.sh}"
  ntfy_topic=$(awk '/^topic=/{sub(/^topic=/,""); gsub(/"/,""); t=$0} END{print t}' "$ntfy_conf")
  if [[ -z "$ntfy_topic" ]]; then
    log_step WARN "ntfy" "config missing topic"
  # kcov-ignore-start  kcov counts each line of the multi-line -d message string, but the elif is one command credited to its closing line; the curl path is exercised by test_ntfy_curl_failure_recorded_as_fail
  elif curl -sS --max-time 5 -d "[claude-guard panic] $ts
workspace: $workspace_folder
reason: ${reason:-(none)}
snapshot: $snapshot_dir" "$ntfy_url/$ntfy_topic" >/dev/null 2>&1; then
    # kcov-ignore-end
    log_step OK "ntfy" "sent to $ntfy_url/$ntfy_topic"
  else
    log_step FAIL "ntfy" "post failed"
  fi
fi

# Force the snapshot files to disk before hashing them. panic runs exactly when the
# host may be powered off or the session killed moments later; the bare `cp`/`docker
# logs` redirects above only reach the page cache, so a crash before writeback would
# leave a truncated file whose sha256 (the tamper-evidence anchor, written last)
# records a hash of bytes that never durably landed. Sync the dir specifically, with
# a global sync fallback for platforms whose `sync` takes no path argument.
sync "$snapshot_dir" 2>/dev/null || sync 2>/dev/null || true

# Anchor for "was this snapshot edited later?" Best-effort. BSD/macOS has no
# `sha256sum` (it ships `shasum -a 256`), so fall back to it — otherwise every
# artifact hash comes out empty on a Mac and the integrity anchor is silently lost.
hashes=""
for f in "$snapshot_dir"/*; do
  [[ -f "$f" ]] || continue
  [[ "$(basename "$f")" == "panic-report.md" ]] && continue
  h=$({ sha256sum "$f" 2>/dev/null || shasum -a 256 "$f" 2>/dev/null; } | cut -d' ' -f1) || continue
  hashes+=$'\n'"  $(basename "$f"): $h"
done

# Reflect the actual kill-switch outcome, not just the flag: "no" when
# --keep-running skipped it, "none" when nothing matched the workspace, else "yes".
if "$keep_running"; then
  _containers_stopped=no
elif ((${#container_ids[@]} > 0)); then
  _containers_stopped=yes
else
  _containers_stopped=none
fi
if "$keep_running"; then
  _sandboxes_removed=no
elif ((${#sbx_names[@]} > 0)); then
  _sandboxes_removed="$sbx_removed of ${#sbx_names[@]}"
else
  _sandboxes_removed=none
fi
{
  printf '%s\n\n' "# claude-guard panic report"
  printf '%s\n' "- timestamp: $ts" \
    "- workspace: $workspace_folder" \
    "- workspace id: $ws_id" \
    "- snapshot dir: $snapshot_dir" \
    "- reason: ${reason:-(none)}" \
    "- archive: $("$do_archive" && echo yes || echo no)" \
    "- containers stopped: $_containers_stopped" \
    "- sandboxes removed: $_sandboxes_removed (removal ignores CLAUDE_PERSIST — an incident kill is deliberate)"
  printf '\n## Steps (%d total, %d failed)\n%s\n' "$step_count" "$fail_count" "$report"
  printf '\n## Artifact sha256\n%s\n' "$hashes"
} >"$snapshot_dir/panic-report.md" # kcov-ignore-line  kcov credits the redirected brace group to its opening line, not this closing `} >file`; the report body is covered by the snapshot tests

printf '\nclaude-guard panic: %d step(s), %d failed\n' "$step_count" "$fail_count" >&2
printf 'claude-guard panic: report -> %s/panic-report.md\n' "$snapshot_dir" >&2
((fail_count > 0)) && {
  cg_warn "claude-guard panic: WARNING — $fail_count step(s) failed; see report"
  exit 1
}
exit 0
